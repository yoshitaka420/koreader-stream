+local function makeRemoteOptions(options)
+    assert(type(options) == "table", "remote document options must be a table")
+    assert(type(options.url) == "string" and options.url ~= "", "remote document URL is required")
+    local remote = ffi.new("mupdf_webdav_stream_options")
+    remote.url = options.url
+    remote.username = options.username or ""
+    remote.password = options.password or ""
+    remote.etag = options.etag or ""
+    remote.last_modified = options.last_modified or ""
+    remote.content_length = options.expected_size or options.content_length or 0
+    remote.block_size = options.block_size or 1024 * 1024
+    remote.cache_limit = options.cache_limit or 32 * 1024 * 1024
+    remote.opening_transfer_limit = options.opening_transfer_limit or 0
+    remote.operation_transfer_limit = options.operation_transfer_limit or 0
+    remote.connect_timeout_ms = options.connect_timeout_ms or 15000
+    remote.transfer_timeout_ms = options.transfer_timeout_ms or 60000
+    remote.strict_mode = options.strict_mode and 1 or 0
+    return remote
+end
+
+--- Perform a bounded one-byte range probe without opening a document.
+function mupdf.probeRemote(options)
+    local ctx = context()
+    local remote = makeRemoteOptions(options)
+    -- The native probe uses these values solely to validate its one-byte
+    -- response buffer; no block cache is retained.
+    remote.block_size = 1
+    remote.cache_limit = 1
+    local result = ffi.new("mupdf_webdav_probe_result")
+    if W.mupdf_probe_webdav_range(ctx, remote, result) == 0 then
+        merror(ctx, "Remote range probe failed")
+    end
+    return {
+        content_length = tonumber(result.content_length),
+        etag = result.etag[0] ~= 0 and ffi.string(result.etag) or nil,
+        last_modified = result.last_modified[0] ~= 0 and ffi.string(result.last_modified) or nil,
+        strong_etag = result.strong_etag ~= 0,
+        http_status = tonumber(result.http_status),
+    }
+end
+
+--- Open a seekable remote CBZ/CBR through MuPDF.
+function mupdf.openRemoteDocument(options)
+    local ctx = context()
+    local remote = makeRemoteOptions(options)
+    local stream = W.mupdf_new_webdav_range_stream(ctx, remote)
+    if stream == nil then
+        merror(ctx, "Cannot create remote range stream")
+    end
+
+    local magic = options.magic or options.display_name or ("remote." .. (options.extension or "cbz"))
+    local doc = W.mupdf_open_document_with_stream_and_dir(ctx, magic, stream, nil)
+    if doc == nil then
+        local remote_error = W.mupdf_webdav_stream_last_error(stream)
+        local message
+        if remote_error ~= nil and remote_error[0] ~= 0 then
+            -- Archive handlers may translate a stream exception into a
+            -- generic "cannot recognize archive" error. Preserve the
+            -- actionable range/auth/strict-limit failure instead.
+            message = ffi.string(remote_error)
+        else
+            message = merror_message(ctx, "MuPDF cannot open remote document")
+        end
+        drop_failed_remote_open(ctx, nil, stream)
+        error(message)
+    end
+
+    -- Counting pages can force lazy archive indexing, so it remains part of
+    -- the opening budget. Do it before installing Lua finalizers so every
+    -- failure path can release native resources synchronously.
+    local pages = W.mupdf_count_pages(ctx, doc)
+    local remote_error = W.mupdf_webdav_stream_last_error(stream)
+    if (remote_error ~= nil and remote_error[0] ~= 0) or pages <= 0 then
+        local message
+        if remote_error ~= nil and remote_error[0] ~= 0 then
+            message = ffi.string(remote_error)
+        elseif pages == -1 then
+            message = merror_message(ctx, "cannot access remote page tree")
+        else
+            message = "MuPDF found no pages in remote file"
+        end
+        drop_failed_remote_open(ctx, doc, stream)
+        error(message)
+    end
+
+    W.mupdf_webdav_stream_finish_open(stream)
+    local mupdf_doc = {
+        doc = doc,
+        filename = options.display_name,
+        remote_stream = stream,
+        number_of_pages = pages,
+    }
+    mupdf_doc.doc = ffi.gc(mupdf_doc.doc, function(document)
+        drop_document(ctx, document, stream)
+    end)
+    mupdf_doc.ctx = keep_context(ctx)
+    setmetatable(mupdf_doc, document_mt)
+
+    return mupdf_doc
+end
