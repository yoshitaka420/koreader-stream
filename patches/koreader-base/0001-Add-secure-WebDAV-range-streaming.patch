@@ -0,0 +1,867 @@
+#include "webdav-range-stream.h"
+
+#include <curl/curl.h>
+
+#include <ctype.h>
+#include <inttypes.h>
+#include <limits.h>
+#include <pthread.h>
+#include <stdarg.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <strings.h>
+
+typedef struct range_block {
+    int64_t index;
+    size_t length;
+    unsigned char *data;
+    struct range_block *newer;
+    struct range_block *older;
+} range_block;
+
+typedef struct webdav_range_state {
+    char *url;
+    char *username;
+    char *password;
+    char *etag;
+    char *last_modified;
+    int strong_etag;
+
+    int64_t content_length;
+    size_t block_size;
+    size_t cache_limit;
+    size_t cached_bytes;
+    size_t peak_cached_bytes;
+    range_block *newest;
+    range_block *oldest;
+
+    CURL *curl;
+    long connect_timeout_ms;
+    long transfer_timeout_ms;
+    int initial_url_is_https;
+
+    uint64_t opening_transfer_limit;
+    uint64_t operation_transfer_limit;
+    uint64_t operation_start_bytes;
+    int strict_mode;
+    int opening_phase;
+    int operation_active;
+
+    uint64_t request_count;
+    uint64_t retry_count;
+    uint64_t bytes_received;
+    uint64_t cache_hits;
+    uint64_t cache_misses;
+    uint64_t opening_bytes;
+    uint64_t operation_limit_hits;
+    uint64_t sequential_run;
+    uint64_t longest_sequential_run;
+    int64_t last_miss_index;
+    long last_http_status;
+
+    int error_code;
+    char error_message[MUPDF_WEBDAV_ERROR_MAX];
+
+    char response_content_range[128];
+    char response_etag[MUPDF_WEBDAV_ETAG_MAX];
+    char response_last_modified[MUPDF_WEBDAV_LAST_MODIFIED_MAX];
+    int response_header_too_long;
+
+    unsigned char empty[1];
+} webdav_range_state;
+
+typedef struct write_target {
+    webdav_range_state *state;
+    unsigned char *data;
+    size_t capacity;
+    size_t length;
+} write_target;
+
+static pthread_once_t curl_once = PTHREAD_ONCE_INIT;
+static CURLcode curl_global_status = CURLE_FAILED_INIT;
+
+static void init_curl(void)
+{
+    curl_global_status = curl_global_init(CURL_GLOBAL_DEFAULT);
+}
+
+static void secure_zero(void *ptr, size_t length)
+{
+    volatile unsigned char *p = (volatile unsigned char *)ptr;
+    while (length--)
+        *p++ = 0;
+}
+
+static void copy_string(char *destination, size_t capacity, const char *source)
+{
+    size_t length;
+    if (capacity == 0)
+        return;
+    if (!source)
+        source = "";
+    length = strlen(source);
+    if (length >= capacity)
+        length = capacity - 1;
+    memcpy(destination, source, length);
+    destination[length] = '\0';
+}
+
+static void set_error(webdav_range_state *state, int code, const char *format, ...)
+{
+    va_list args;
+    state->error_code = code;
+    va_start(args, format);
+    vsnprintf(state->error_message, sizeof(state->error_message), format, args);
+    va_end(args);
+}
+
+static void clear_error(webdav_range_state *state)
+{
+    state->error_code = MUPDF_WEBDAV_ERROR_NONE;
+    state->error_message[0] = '\0';
+}
+
+static int is_strong_etag(const char *etag)
+{
+    return etag && etag[0] == '"' && strlen(etag) >= 2 && etag[strlen(etag) - 1] == '"';
+}
+
+static int url_is_valid(const char *url, int *is_https)
+{
+    const char *authority;
+    const char *authority_end;
+    if (!url)
+        return 0;
+    if (strncasecmp(url, "https://", 8) == 0) {
+        authority = url + 8;
+        *is_https = 1;
+    } else if (strncasecmp(url, "http://", 7) == 0) {
+        authority = url + 7;
+        *is_https = 0;
+    } else {
+        return 0;
+    }
+    authority_end = authority + strcspn(authority, "/?#");
+    if (authority == authority_end || memchr(authority, '@', (size_t)(authority_end - authority)))
+        return 0;
+    return 1;
+}
+
+static int header_value_is_safe(const char *value)
+{
+    return !value || strpbrk(value, "\r\n") == NULL;
+}
+
+static void response_reset(webdav_range_state *state)
+{
+    state->response_content_range[0] = '\0';
+    state->response_etag[0] = '\0';
+    state->response_last_modified[0] = '\0';
+    state->response_header_too_long = 0;
+}
+
+static void store_header(webdav_range_state *state, char *destination, size_t capacity,
+                         const char *start, const char *end)
+{
+    size_t length;
+    while (start < end && isspace((unsigned char)*start))
+        start++;
+    while (end > start && isspace((unsigned char)end[-1]))
+        end--;
+    length = (size_t)(end - start);
+    if (length >= capacity) {
+        state->response_header_too_long = 1;
+        destination[0] = '\0';
+        return;
+    }
+    memcpy(destination, start, length);
+    destination[length] = '\0';
+}
+
+static size_t header_callback(char *buffer, size_t size, size_t count, void *userdata)
+{
+    webdav_range_state *state = (webdav_range_state *)userdata;
+    size_t length = size * count;
+    const char *colon;
+    const char *end = buffer + length;
+    if (length >= 5 && strncasecmp(buffer, "HTTP/", 5) == 0) {
+        response_reset(state);
+        return length;
+    }
+    colon = memchr(buffer, ':', length);
+    if (!colon)
+        return length;
+    if ((size_t)(colon - buffer) == 13 && strncasecmp(buffer, "Content-Range", 13) == 0)
+        store_header(state, state->response_content_range, sizeof(state->response_content_range), colon + 1, end);
+    else if ((size_t)(colon - buffer) == 4 && strncasecmp(buffer, "ETag", 4) == 0)
+        store_header(state, state->response_etag, sizeof(state->response_etag), colon + 1, end);
+    else if ((size_t)(colon - buffer) == 13 && strncasecmp(buffer, "Last-Modified", 13) == 0)
+        store_header(state, state->response_last_modified, sizeof(state->response_last_modified), colon + 1, end);
+    return length;
+}
+
+static int transfer_limit_exceeded(webdav_range_state *state, size_t incoming)
+{
+    uint64_t after;
+    if (!state->strict_mode)
+        return 0;
+    after = state->bytes_received + incoming;
+    if (state->opening_phase && state->opening_transfer_limit > 0 && after > state->opening_transfer_limit) {
+        state->operation_limit_hits++;
+        set_error(state, MUPDF_WEBDAV_ERROR_LIMIT,
+                  "remote stream: opening transfer limit exceeded; this archive cannot be efficiently random-accessed");
+        return 1;
+    }
+    if (state->operation_active && state->operation_transfer_limit > 0 &&
+            after - state->operation_start_bytes > state->operation_transfer_limit) {
+        state->operation_limit_hits++;
+        set_error(state, MUPDF_WEBDAV_ERROR_LIMIT,
+                  "remote stream: page transfer limit exceeded; this CBR is probably solid or otherwise not efficiently seekable");
+        return 1;
+    }
+    return 0;
+}
+
+static size_t write_callback(char *buffer, size_t size, size_t count, void *userdata)
+{
+    write_target *target = (write_target *)userdata;
+    size_t length = size * count;
+    if (length == 0)
+        return 0;
+    if (transfer_limit_exceeded(target->state, length)) {
+        /* libcurl has already delivered this chunk to us even though strict
+         * mode rejects it, so include it in diagnostic network totals. */
+        target->state->bytes_received += length;
+        return 0;
+    }
+    target->state->bytes_received += length;
+    if (length > target->capacity - target->length) {
+        set_error(target->state, MUPDF_WEBDAV_ERROR_RESPONSE,
+                  "remote stream: server returned more data than requested");
+        return 0;
+    }
+    memcpy(target->data + target->length, buffer, length);
+    target->length += length;
+    return length;
+}
+
+static int parse_content_range(const char *value, int64_t *start, int64_t *end, int64_t *total)
+{
+    char trailing;
+    return value && sscanf(value, "bytes %" SCNd64 "-%" SCNd64 "/%" SCNd64 " %c",
+                           start, end, total, &trailing) == 3;
+}
+
+static int curl_error_is_tls(CURLcode code)
+{
+    return code == CURLE_PEER_FAILED_VERIFICATION || code == CURLE_SSL_CONNECT_ERROR ||
+           code == CURLE_SSL_CERTPROBLEM || code == CURLE_SSL_CACERT_BADFILE ||
+           code == CURLE_USE_SSL_FAILED;
+}
+
+static int curl_error_is_retryable(CURLcode code)
+{
+    return code == CURLE_COULDNT_CONNECT || code == CURLE_COULDNT_RESOLVE_HOST ||
+           code == CURLE_RECV_ERROR || code == CURLE_SEND_ERROR ||
+           code == CURLE_GOT_NOTHING || code == CURLE_PARTIAL_FILE ||
+           code == CURLE_OPERATION_TIMEDOUT;
+}
+
+static int configure_curl(webdav_range_state *state)
+{
+#define SETOPT(option, value) do { if (curl_easy_setopt(state->curl, option, value) != CURLE_OK) return 0; } while (0)
+    SETOPT(CURLOPT_URL, state->url);
+    SETOPT(CURLOPT_NOSIGNAL, 1L);
+    SETOPT(CURLOPT_FOLLOWLOCATION, 1L);
+    SETOPT(CURLOPT_MAXREDIRS, 5L);
+    SETOPT(CURLOPT_UNRESTRICTED_AUTH, 0L);
+    SETOPT(CURLOPT_PROTOCOLS_STR, "http,https");
+    SETOPT(CURLOPT_REDIR_PROTOCOLS_STR, state->initial_url_is_https ? "https" : "http,https");
+    SETOPT(CURLOPT_SSL_VERIFYPEER, 1L);
+    SETOPT(CURLOPT_SSL_VERIFYHOST, 2L);
+    SETOPT(CURLOPT_CONNECTTIMEOUT_MS, state->connect_timeout_ms);
+    SETOPT(CURLOPT_TIMEOUT_MS, state->transfer_timeout_ms);
+    SETOPT(CURLOPT_LOW_SPEED_LIMIT, 1L);
+    SETOPT(CURLOPT_LOW_SPEED_TIME, 30L);
+    SETOPT(CURLOPT_TCP_KEEPALIVE, 1L);
+    SETOPT(CURLOPT_HTTPAUTH, (long)CURLAUTH_ANY);
+    SETOPT(CURLOPT_USERNAME, state->username);
+    SETOPT(CURLOPT_PASSWORD, state->password);
+    SETOPT(CURLOPT_HEADERFUNCTION, header_callback);
+    SETOPT(CURLOPT_HEADERDATA, state);
+    return 1;
+#undef SETOPT
+}
+
+static void clear_blocks(fz_context *ctx, webdav_range_state *state)
+{
+    range_block *block = state->newest;
+    while (block) {
+        range_block *next = block->older;
+        if (block->data) {
+            secure_zero(block->data, block->length);
+            fz_free(ctx, block->data);
+        }
+        fz_free(ctx, block);
+        block = next;
+    }
+    state->newest = NULL;
+    state->oldest = NULL;
+    state->cached_bytes = 0;
+}
+
+static void drop_state(fz_context *ctx, void *opaque)
+{
+    webdav_range_state *state = (webdav_range_state *)opaque;
+    if (!state)
+        return;
+    clear_blocks(ctx, state);
+    if (state->curl) {
+        curl_easy_setopt(state->curl, CURLOPT_USERNAME, "");
+        curl_easy_setopt(state->curl, CURLOPT_PASSWORD, "");
+        curl_easy_cleanup(state->curl);
+    }
+    if (state->password) {
+        secure_zero(state->password, strlen(state->password));
+        fz_free(ctx, state->password);
+    }
+    if (state->username) {
+        secure_zero(state->username, strlen(state->username));
+        fz_free(ctx, state->username);
+    }
+    if (state->url) {
+        secure_zero(state->url, strlen(state->url));
+        fz_free(ctx, state->url);
+    }
+    if (state->etag) {
+        secure_zero(state->etag, strlen(state->etag));
+        fz_free(ctx, state->etag);
+    }
+    if (state->last_modified) {
+        secure_zero(state->last_modified, strlen(state->last_modified));
+        fz_free(ctx, state->last_modified);
+    }
+    secure_zero(state->error_message, sizeof(state->error_message));
+    fz_free(ctx, state);
+}
+
+static webdav_range_state *new_state(fz_context *ctx, const mupdf_webdav_stream_options *options,
+                                     int allow_unknown_length)
+{
+    webdav_range_state *state = NULL;
+    if (!options || !options->url)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: URL is required");
+    if (!allow_unknown_length && options->content_length <= 0)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: a positive content length is required");
+    if (options->block_size == 0 || options->cache_limit < options->block_size)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: invalid block cache configuration");
+
+    fz_var(state);
+    fz_try(ctx) {
+        state = fz_calloc(ctx, 1, sizeof(*state));
+        if (!url_is_valid(options->url, &state->initial_url_is_https))
+            fz_throw(ctx, FZ_ERROR_ARGUMENT,
+                     "remote stream: URL must be HTTP(S) and must not contain user-info");
+        state->url = fz_strdup(ctx, options->url);
+        state->username = fz_strdup(ctx, options->username ? options->username : "");
+        state->password = fz_strdup(ctx, options->password ? options->password : "");
+        state->etag = fz_strdup(ctx, options->etag ? options->etag : "");
+        state->last_modified = fz_strdup(ctx, options->last_modified ? options->last_modified : "");
+        if (strlen(state->etag) >= MUPDF_WEBDAV_ETAG_MAX ||
+                strlen(state->last_modified) >= MUPDF_WEBDAV_LAST_MODIFIED_MAX)
+            fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: validator header is too long");
+        if (!header_value_is_safe(state->etag) || !header_value_is_safe(state->last_modified))
+            fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: invalid validator header");
+        state->strong_etag = is_strong_etag(state->etag);
+        state->content_length = options->content_length;
+        state->block_size = options->block_size;
+        state->cache_limit = options->cache_limit;
+        state->opening_transfer_limit = options->opening_transfer_limit;
+        state->operation_transfer_limit = options->operation_transfer_limit;
+        state->strict_mode = options->strict_mode;
+        state->opening_phase = 1;
+        state->last_miss_index = -2;
+        state->connect_timeout_ms = options->connect_timeout_ms > 0 ? options->connect_timeout_ms : 15000;
+        state->transfer_timeout_ms = options->transfer_timeout_ms > 0 ? options->transfer_timeout_ms : 60000;
+
+        pthread_once(&curl_once, init_curl);
+        if (curl_global_status != CURLE_OK)
+            fz_throw(ctx, FZ_ERROR_SYSTEM, "remote stream: libcurl initialization failed");
+        state->curl = curl_easy_init();
+        if (!state->curl || !configure_curl(state))
+            fz_throw(ctx, FZ_ERROR_SYSTEM, "remote stream: libcurl setup failed");
+    }
+    fz_catch(ctx) {
+        drop_state(ctx, state);
+        fz_rethrow(ctx);
+    }
+    return state;
+}
+
+static int append_header(struct curl_slist **headers, const char *value)
+{
+    struct curl_slist *appended = curl_slist_append(*headers, value);
+    if (!appended)
+        return 0;
+    *headers = appended;
+    return 1;
+}
+
+static int perform_range_request(webdav_range_state *state, int64_t requested_start,
+                                 int64_t requested_end, unsigned char *data, size_t capacity,
+                                 size_t *received)
+{
+    char range_header[96];
+    char if_range_header[MUPDF_WEBDAV_ETAG_MAX + 32];
+    struct curl_slist *headers = NULL;
+    write_target target;
+    CURLcode status = CURLE_OK;
+    int attempt;
+    int64_t actual_start = -1, actual_end = -1, actual_total = -1;
+
+    /* MuPDF's archive and comic handlers may catch a stream exception and
+     * continue. Keep the first failure sticky for the current open/page
+     * operation so a later read cannot erase its actionable diagnostic.
+     * begin_operation() explicitly clears it when the user retries a page. */
+    if (state->error_code != MUPDF_WEBDAV_ERROR_NONE)
+        return 0;
+
+    snprintf(range_header, sizeof(range_header), "Range: bytes=%" PRId64 "-%" PRId64,
+             requested_start, requested_end);
+    if (!append_header(&headers, range_header) ||
+            !append_header(&headers, "Accept-Encoding: identity") ||
+            !append_header(&headers, "Cache-Control: no-transform"))
+        goto header_allocation_failed;
+    if (state->strong_etag && state->etag[0]) {
+        snprintf(if_range_header, sizeof(if_range_header), "If-Range: %s", state->etag);
+        if (!append_header(&headers, if_range_header))
+            goto header_allocation_failed;
+    } else if (state->last_modified[0]) {
+        snprintf(if_range_header, sizeof(if_range_header), "If-Range: %s", state->last_modified);
+        if (!append_header(&headers, if_range_header))
+            goto header_allocation_failed;
+    }
+
+    target.state = state;
+    target.data = data;
+    target.capacity = capacity;
+    target.length = 0;
+    for (attempt = 0; attempt < 2; attempt++) {
+        response_reset(state);
+        target.length = 0;
+        state->request_count++;
+        curl_easy_setopt(state->curl, CURLOPT_HTTPHEADER, headers);
+        curl_easy_setopt(state->curl, CURLOPT_WRITEFUNCTION, write_callback);
+        curl_easy_setopt(state->curl, CURLOPT_WRITEDATA, &target);
+        curl_easy_setopt(state->curl, CURLOPT_FRESH_CONNECT, attempt == 0 ? 0L : 1L);
+        status = curl_easy_perform(state->curl);
+        curl_easy_getinfo(state->curl, CURLINFO_RESPONSE_CODE, &state->last_http_status);
+        if (status == CURLE_OK || state->error_code != MUPDF_WEBDAV_ERROR_NONE ||
+                !curl_error_is_retryable(status) || attempt == 1)
+            break;
+        state->retry_count++;
+    }
+    curl_easy_setopt(state->curl, CURLOPT_HTTPHEADER, NULL);
+    curl_slist_free_all(headers);
+
+    /* A server that ignores Range may overrun our deliberately small response
+     * buffer, causing CURLE_WRITE_ERROR. Classify the HTTP response first so a
+     * bounded probe still reports the useful "no range"/"changed" error. */
+    if (state->last_http_status == 401 || state->last_http_status == 403) {
+        set_error(state, MUPDF_WEBDAV_ERROR_AUTH, "remote stream: authentication failed");
+        return 0;
+    }
+    if (state->last_http_status == 404 || state->last_http_status == 410) {
+        set_error(state, MUPDF_WEBDAV_ERROR_UNAVAILABLE, "remote stream: remote file is unavailable");
+        return 0;
+    }
+    if (state->last_http_status != 0 && state->last_http_status != 206) {
+        if (state->last_http_status == 200 && (state->etag[0] || state->last_modified[0]))
+            set_error(state, MUPDF_WEBDAV_ERROR_CHANGED, "remote stream: remote file changed");
+        else if (state->last_http_status == 200)
+            set_error(state, MUPDF_WEBDAV_ERROR_NO_RANGE, "remote stream: server ignored the byte range request");
+        else
+            set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE,
+                      "remote stream: server returned HTTP %ld instead of 206", state->last_http_status);
+        return 0;
+    }
+    if (state->error_code != MUPDF_WEBDAV_ERROR_NONE)
+        return 0;
+    if (status != CURLE_OK) {
+        if (status == CURLE_OPERATION_TIMEDOUT)
+            set_error(state, MUPDF_WEBDAV_ERROR_TIMEOUT, "remote stream: request timed out");
+        else if (status == CURLE_PARTIAL_FILE && state->last_http_status == 206)
+            set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE, "remote stream: truncated byte range response");
+        else if (curl_error_is_tls(status))
+            set_error(state, MUPDF_WEBDAV_ERROR_TLS, "remote stream: TLS verification or handshake failed");
+        else
+            set_error(state, MUPDF_WEBDAV_ERROR_NETWORK, "remote stream: network request failed (%d)", (int)status);
+        return 0;
+    }
+    if (state->last_http_status != 206) {
+        set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE,
+                  "remote stream: server returned HTTP %ld instead of 206", state->last_http_status);
+        return 0;
+    }
+    if (state->response_header_too_long ||
+            !parse_content_range(state->response_content_range, &actual_start, &actual_end, &actual_total)) {
+        set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE, "remote stream: invalid or missing Content-Range");
+        return 0;
+    }
+    if (actual_start != requested_start || actual_end != requested_end || actual_total <= 0) {
+        set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE, "remote stream: Content-Range does not match the request");
+        return 0;
+    }
+    if (state->content_length > 0 && actual_total != state->content_length) {
+        set_error(state, MUPDF_WEBDAV_ERROR_CHANGED, "remote stream: remote file size changed");
+        return 0;
+    }
+    if (state->content_length <= 0)
+        state->content_length = actual_total;
+    /* Weak (or malformed) ETags are not valid If-Range validators. They may
+     * also come from a PROPFIND endpoint in front of a different GET/CDN
+     * representation. Only require an ETag when it is genuinely strong;
+     * otherwise validate Last-Modified and the Content-Range total. */
+    if (state->strong_etag) {
+        if (!state->response_etag[0]) {
+            set_error(state, MUPDF_WEBDAV_ERROR_CHANGED,
+                      "remote stream: server omitted the expected ETag");
+            return 0;
+        }
+        if (strcmp(state->etag, state->response_etag) != 0) {
+            set_error(state, MUPDF_WEBDAV_ERROR_CHANGED, "remote stream: remote file ETag changed");
+            return 0;
+        }
+    }
+    if (!state->strong_etag && state->last_modified[0]) {
+        if (!state->response_last_modified[0]) {
+            set_error(state, MUPDF_WEBDAV_ERROR_CHANGED,
+                      "remote stream: server omitted the expected Last-Modified value");
+            return 0;
+        }
+        if (strcmp(state->last_modified, state->response_last_modified) != 0) {
+            set_error(state, MUPDF_WEBDAV_ERROR_CHANGED,
+                      "remote stream: remote file Last-Modified value changed");
+            return 0;
+        }
+    }
+    if (target.length != (size_t)(requested_end - requested_start + 1)) {
+        set_error(state, MUPDF_WEBDAV_ERROR_RESPONSE, "remote stream: truncated byte range response");
+        return 0;
+    }
+    *received = target.length;
+    return 1;
+
+header_allocation_failed:
+    curl_slist_free_all(headers);
+    set_error(state, MUPDF_WEBDAV_ERROR_NETWORK,
+              "remote stream: cannot allocate HTTP headers");
+    return 0;
+}
+
+static range_block *find_block(webdav_range_state *state, int64_t index)
+{
+    range_block *block;
+    for (block = state->newest; block; block = block->older)
+        if (block->index == index)
+            return block;
+    return NULL;
+}
+
+static void unlink_block(webdav_range_state *state, range_block *block)
+{
+    if (block->newer)
+        block->newer->older = block->older;
+    else
+        state->newest = block->older;
+    if (block->older)
+        block->older->newer = block->newer;
+    else
+        state->oldest = block->newer;
+    block->newer = NULL;
+    block->older = NULL;
+}
+
+static void make_newest(webdav_range_state *state, range_block *block)
+{
+    if (state->newest == block)
+        return;
+    if (block->newer || block->older || state->oldest == block)
+        unlink_block(state, block);
+    block->older = state->newest;
+    if (state->newest)
+        state->newest->newer = block;
+    else
+        state->oldest = block;
+    state->newest = block;
+}
+
+static void evict_oldest(fz_context *ctx, webdav_range_state *state)
+{
+    range_block *block = state->oldest;
+    if (!block)
+        return;
+    unlink_block(state, block);
+    state->cached_bytes -= block->length;
+    secure_zero(block->data, block->length);
+    fz_free(ctx, block->data);
+    fz_free(ctx, block);
+}
+
+static range_block *fetch_block(fz_context *ctx, webdav_range_state *state, int64_t index)
+{
+    range_block *block = NULL;
+    int64_t start;
+    int64_t end;
+    size_t wanted;
+    size_t received = 0;
+
+    if (index < 0 || index > INT64_MAX / (int64_t)state->block_size) {
+        set_error(state, MUPDF_WEBDAV_ERROR_ARGUMENT, "remote stream: invalid block index");
+        return NULL;
+    }
+    start = index * (int64_t)state->block_size;
+    if (start >= state->content_length)
+        return NULL;
+    end = start + (int64_t)state->block_size - 1;
+    if (end < start || end >= state->content_length)
+        end = state->content_length - 1;
+    wanted = (size_t)(end - start + 1);
+
+    fz_var(block);
+    fz_try(ctx) {
+        block = fz_calloc(ctx, 1, sizeof(*block));
+        /* Evict before allocating the incoming block so the block buffers
+         * never transiently exceed the configured RAM ceiling. */
+        while (state->cached_bytes + wanted > state->cache_limit)
+            evict_oldest(ctx, state);
+        block->data = fz_malloc(ctx, wanted);
+        if (!perform_range_request(state, start, end, block->data, wanted, &received))
+            break;
+        block->index = index;
+        block->length = received;
+        make_newest(state, block);
+        state->cached_bytes += block->length;
+        if (state->cached_bytes > state->peak_cached_bytes)
+            state->peak_cached_bytes = state->cached_bytes;
+    }
+    fz_catch(ctx) {
+        if (block) {
+            if (block->data)
+                fz_free(ctx, block->data);
+            fz_free(ctx, block);
+        }
+        fz_rethrow(ctx);
+    }
+    if (state->error_code != MUPDF_WEBDAV_ERROR_NONE) {
+        if (block) {
+            if (block->data) {
+                secure_zero(block->data, wanted);
+                fz_free(ctx, block->data);
+            }
+            fz_free(ctx, block);
+        }
+        clear_blocks(ctx, state);
+        return NULL;
+    }
+    return block;
+}
+
+static int next_range(fz_context *ctx, fz_stream *stream, size_t max)
+{
+    webdav_range_state *state = (webdav_range_state *)stream->state;
+    int64_t position = stream->pos;
+    int64_t index;
+    int64_t block_start;
+    size_t offset;
+    range_block *block;
+    (void)max;
+
+    if (position >= state->content_length)
+        return EOF;
+    if (position < 0)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: negative read position");
+    index = position / (int64_t)state->block_size;
+    block = find_block(state, index);
+    if (block) {
+        state->cache_hits++;
+        make_newest(state, block);
+    } else {
+        state->cache_misses++;
+        if (index == state->last_miss_index + 1)
+            state->sequential_run += state->block_size;
+        else
+            state->sequential_run = state->block_size;
+        state->last_miss_index = index;
+        if (state->sequential_run > state->longest_sequential_run)
+            state->longest_sequential_run = state->sequential_run;
+        block = fetch_block(ctx, state, index);
+        if (!block) {
+            if (state->error_code != MUPDF_WEBDAV_ERROR_NONE) {
+                /* fetch_block clears the LRU after an error; do not leave
+                 * MuPDF pointing at the just-evicted block on a later retry. */
+                stream->rp = state->empty;
+                stream->wp = state->empty;
+                fz_throw(ctx, FZ_ERROR_SYSTEM, "%s", state->error_message);
+            }
+            return EOF;
+        }
+    }
+    block_start = index * (int64_t)state->block_size;
+    offset = (size_t)(position - block_start);
+    if (offset >= block->length)
+        fz_throw(ctx, FZ_ERROR_FORMAT, "remote stream: cached block is shorter than expected");
+    stream->rp = block->data + offset;
+    stream->wp = block->data + block->length;
+    stream->pos = block_start + (int64_t)block->length;
+    return *stream->rp++;
+}
+
+static void seek_range(fz_context *ctx, fz_stream *stream, int64_t offset, int whence)
+{
+    webdav_range_state *state = (webdav_range_state *)stream->state;
+    int64_t position;
+    if (whence == SEEK_SET)
+        position = offset;
+    else if (whence == SEEK_END) {
+        if ((offset > 0 && state->content_length > INT64_MAX - offset) ||
+                (offset < 0 && state->content_length < INT64_MIN - offset))
+            fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: seek overflow");
+        position = state->content_length + offset;
+    } else {
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: unsupported seek origin");
+    }
+    if (position < 0)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: negative seek position");
+    stream->pos = position;
+    stream->rp = state->empty;
+    stream->wp = state->empty;
+}
+
+static webdav_range_state *state_from_stream(fz_stream *stream)
+{
+    if (!stream || stream->next != next_range)
+        return NULL;
+    return (webdav_range_state *)stream->state;
+}
+
+fz_stream *webdav_range_stream_open(fz_context *ctx, const mupdf_webdav_stream_options *options)
+{
+    webdav_range_state *state = new_state(ctx, options, 0);
+    fz_stream *stream = NULL;
+    fz_var(stream);
+    fz_try(ctx) {
+        stream = fz_new_stream(ctx, state, next_range, drop_state);
+        state = NULL;
+        stream->seek = seek_range;
+        stream->rp = ((webdav_range_state *)stream->state)->empty;
+        stream->wp = ((webdav_range_state *)stream->state)->empty;
+    }
+    fz_catch(ctx) {
+        drop_state(ctx, state);
+        fz_rethrow(ctx);
+    }
+    return stream;
+}
+
+int webdav_range_stream_probe(fz_context *ctx, const mupdf_webdav_stream_options *options,
+                              mupdf_webdav_probe_result *result)
+{
+    webdav_range_state *state = NULL;
+    unsigned char byte = 0;
+    size_t received = 0;
+    int ok = 0;
+    char error[MUPDF_WEBDAV_ERROR_MAX];
+    int error_code;
+
+    if (!result)
+        fz_throw(ctx, FZ_ERROR_ARGUMENT, "remote stream: probe result is required");
+    memset(result, 0, sizeof(*result));
+    state = new_state(ctx, options, 1);
+    if (perform_range_request(state, 0, 0, &byte, 1, &received)) {
+        result->content_length = state->content_length;
+        result->strong_etag = is_strong_etag(state->response_etag);
+        result->http_status = state->last_http_status;
+        copy_string(result->etag, sizeof(result->etag), state->response_etag);
+        copy_string(result->last_modified, sizeof(result->last_modified), state->response_last_modified);
+        ok = 1;
+    } else {
+        error_code = state->error_code;
+        copy_string(error, sizeof(error), state->error_message);
+        result->error_code = error_code;
+        result->http_status = state->last_http_status;
+        copy_string(result->error_message, sizeof(result->error_message), error);
+    }
+    drop_state(ctx, state);
+    if (!ok)
+        fz_throw(ctx, FZ_ERROR_SYSTEM, "%s", result->error_message);
+    return 1;
+}
+
+void webdav_range_stream_finish_open(fz_stream *stream)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    if (!state)
+        return;
+    state->opening_phase = 0;
+    state->opening_bytes = state->bytes_received;
+}
+
+void webdav_range_stream_begin_operation(fz_stream *stream)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    if (!state)
+        return;
+    clear_error(state);
+    state->operation_active = 1;
+    state->operation_start_bytes = state->bytes_received;
+}
+
+void webdav_range_stream_end_operation(fz_stream *stream)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    if (state)
+        state->operation_active = 0;
+}
+
+void webdav_range_stream_clear_cache(fz_context *ctx, fz_stream *stream)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    if (state) {
+        int64_t position = stream->pos - (int64_t)(stream->wp - stream->rp);
+        stream->rp = state->empty;
+        stream->wp = state->empty;
+        stream->pos = position;
+        clear_blocks(ctx, state);
+    }
+}
+
+int webdav_range_stream_get_stats(fz_stream *stream, mupdf_webdav_stream_stats *stats)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    if (!state || !stats)
+        return 0;
+    memset(stats, 0, sizeof(*stats));
+    stats->content_length = state->content_length;
+    stats->request_count = state->request_count;
+    stats->retry_count = state->retry_count;
+    stats->bytes_received = state->bytes_received;
+    stats->cache_hits = state->cache_hits;
+    stats->cache_misses = state->cache_misses;
+    stats->cached_bytes = state->cached_bytes;
+    stats->peak_cached_bytes = state->peak_cached_bytes;
+    stats->opening_bytes = state->opening_bytes;
+    stats->operation_limit_hits = state->operation_limit_hits;
+    stats->longest_sequential_run = state->longest_sequential_run;
+    stats->last_http_status = state->last_http_status;
+    stats->error_code = state->error_code;
+    return 1;
+}
+
+const char *webdav_range_stream_last_error(fz_stream *stream)
+{
+    webdav_range_state *state = state_from_stream(stream);
+    return state ? state->error_message : "";
+}
