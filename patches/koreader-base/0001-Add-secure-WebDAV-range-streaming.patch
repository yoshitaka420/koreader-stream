+    MUPDF_WEBDAV_ERROR_NONE = 0,
+    MUPDF_WEBDAV_ERROR_ARGUMENT = 1,
+    MUPDF_WEBDAV_ERROR_NO_RANGE = 2,
+    MUPDF_WEBDAV_ERROR_AUTH = 3,
+    MUPDF_WEBDAV_ERROR_CHANGED = 4,
+    MUPDF_WEBDAV_ERROR_TLS = 5,
+    MUPDF_WEBDAV_ERROR_TIMEOUT = 6,
+    MUPDF_WEBDAV_ERROR_NETWORK = 7,
+    MUPDF_WEBDAV_ERROR_RESPONSE = 8,
+    MUPDF_WEBDAV_ERROR_LIMIT = 9,
+    MUPDF_WEBDAV_ERROR_UNAVAILABLE = 10,
+};
+
+typedef struct mupdf_webdav_stream_options {
+    const char *url;
+    const char *username;
+    const char *password;
+    const char *etag;
+    const char *last_modified;
+    int64_t content_length;
+    size_t block_size;
+    size_t cache_limit;
+    uint64_t opening_transfer_limit;
+    uint64_t operation_transfer_limit;
+    long connect_timeout_ms;
