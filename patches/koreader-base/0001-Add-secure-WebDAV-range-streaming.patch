+function document_mt.__index:getNetworkStats()
+    if self.remote_stream == nil then return end
+    local stats = ffi.new("mupdf_webdav_stream_stats")
+    if W.mupdf_webdav_stream_get_stats(self.remote_stream, stats) == 0 then return end
+    return {
+        content_length = tonumber(stats.content_length),
+        request_count = tonumber(stats.request_count),
+        retry_count = tonumber(stats.retry_count),
+        bytes_received = tonumber(stats.bytes_received),
+        cache_hits = tonumber(stats.cache_hits),
+        cache_misses = tonumber(stats.cache_misses),
+        cached_bytes = tonumber(stats.cached_bytes),
+        peak_cached_bytes = tonumber(stats.peak_cached_bytes),
+        opening_bytes = tonumber(stats.opening_bytes),
+        operation_limit_hits = tonumber(stats.operation_limit_hits),
+        longest_sequential_run = tonumber(stats.longest_sequential_run),
+        last_http_status = tonumber(stats.last_http_status),
+        error_code = tonumber(stats.error_code),
+    }
+end
+
+function document_mt.__index:clearRemoteCache()
+    if self.remote_stream ~= nil then
