--- /dev/null
+++ b/spec/support/webdav_range_server.py
@@ -0,0 +1,216 @@
+#!/usr/bin/env python3
+"""Small adversarial HTTP/WebDAV range server used by KOReader tests.
+
+It deliberately logs only whether Authorization was present, never its value.
+"""
+
+from __future__ import annotations
+
+import argparse
+import base64
+import json
+import os
+import re
+import socket
+import threading
+import time
+import urllib.parse
+from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
+
+
+ETAG = '"fixture-v1"'
+CHANGED_ETAG = '"fixture-v2"'
+LAST_MODIFIED = "Wed, 15 Jul 2026 00:00:00 GMT"
+CHANGED_LAST_MODIFIED = "Thu, 16 Jul 2026 00:00:00 GMT"
+RANGE_RE = re.compile(r"^bytes=(\d+)-(\d*)$")
+
+
+class FixtureServer(ThreadingHTTPServer):
+    daemon_threads = True
+
+    def __init__(self, address, handler, args):
+        super().__init__(address, handler)
+        self.args = args
+        with open(args.file, "rb") as fixture:
+            self.payload = fixture.read()
+        self.log_lock = threading.Lock()
+
+    def log_request_data(self, record):
+        if not self.args.log_file:
+            return
+        with self.log_lock, open(self.args.log_file, "a", encoding="utf-8") as log:
+            log.write(json.dumps(record, sort_keys=True) + "\n")
+            log.flush()
+
+
+class Handler(BaseHTTPRequestHandler):
+    protocol_version = "HTTP/1.1"
+    server_version = "KOReaderRangeFixture/1"
+
+    def log_message(self, _format, *_args):
+        return
+
+    def _authorized(self):
+        if self.server.args.allow_anonymous:
+            return True
+        token = base64.b64encode(
+            f"{self.server.args.username}:{self.server.args.password}".encode()
+        ).decode()
+        return self.headers.get("Authorization") == f"Basic {token}"
+
+    def _reject_auth(self):
+        self.send_response(401)
+        self.send_header("WWW-Authenticate", 'Basic realm="KOReader test"')
+        self.send_header("Content-Length", "0")
+        self.send_header("Connection", "close")
+        self.end_headers()
+        self.server.log_request_data(self._record(401, 0))
+
+    def _record(self, status, sent, mode=None):
+        return {
+            "authorization_present": self.headers.get("Authorization") is not None,
+            "bytes_sent": sent,
+            "if_range": self.headers.get("If-Range"),
+            "method": self.command,
+            "mode": mode,
+            "path": self.path,
+            "range": self.headers.get("Range"),
+            "status": status,
+        }
+
+    def do_PROPFIND(self):
+        if not self._authorized():
+            self._reject_auth()
+            return
+        size = len(self.server.payload)
+        body = f'''<?xml version="1.0" encoding="utf-8"?>
+<d:multistatus xmlns:d="DAV:"><d:response><d:href>/book.cbz</d:href>
+<d:propstat><d:prop><d:resourcetype/><d:getcontentlength>{size}</d:getcontentlength>
+<d:getlastmodified>{LAST_MODIFIED}</d:getlastmodified><d:getetag>{ETAG}</d:getetag>
+</d:prop><d:status>HTTP/1.1 200 OK</d:status></d:propstat></d:response></d:multistatus>'''.encode()
+        self.send_response(207)
+        self.send_header("Content-Type", "application/xml")
+        self.send_header("Content-Length", str(len(body)))
+        self.send_header("Connection", "close")
+        self.end_headers()
+        self.wfile.write(body)
+        self.server.log_request_data(self._record(207, len(body)))
+
+    def do_GET(self):
+        if not self._authorized():
+            self._reject_auth()
+            return
+
+        parsed = urllib.parse.urlsplit(self.path)
+        query = urllib.parse.parse_qs(parsed.query)
+        mode = query.get("mode", [""])[0]
+        if parsed.path == "/redirect":
+            target = query.get("target", ["/book.cbz"])[0]
+            self.send_response(302)
+            self.send_header("Location", target)
+            self.send_header("Content-Length", "0")
+            self.send_header("Connection", "close")
+            self.end_headers()
+            self.server.log_request_data(self._record(302, 0, mode))
+            return
+        if mode == "missing":
+            self.send_response(404)
+            self.send_header("Content-Length", "0")
+            self.send_header("Connection", "close")
+            self.end_headers()
+            self.server.log_request_data(self._record(404, 0, mode))
+            return
+
+        payload = self.server.payload
+        total = len(payload)
+        etag = CHANGED_ETAG if mode == "changed" else ETAG
+        last_modified = (
+            CHANGED_LAST_MODIFIED if mode == "changed-last-modified" else LAST_MODIFIED
+        )
+        range_header = self.headers.get("Range")
+        if_range = self.headers.get("If-Range")
+        ignore_range = mode == "ignore" or (if_range and if_range not in (etag, LAST_MODIFIED))
+
+        start, end, status = 0, total - 1, 200
+        if range_header and not ignore_range:
+            match = RANGE_RE.match(range_header)
+            if not match:
+                self.send_error(400)
+                return
+            start = int(match.group(1))
+            end = int(match.group(2) or total - 1)
+            if start >= total or end < start:
+                self.send_response(416)
+                self.send_header("Content-Range", f"bytes */{total}")
+                self.send_header("Content-Length", "0")
+                self.send_header("Connection", "close")
+                self.end_headers()
+                self.server.log_request_data(self._record(416, 0, mode))
+                return
+            end = min(end, total - 1)
+            status = 206
+
+        body = payload[start : end + 1]
+        advertised_length = len(body)
+        if mode == "truncate" and status == 206 and body:
+            body = body[:-1]
+
+        self.send_response(status)
+        self.send_header("Accept-Ranges", "bytes")
+        if mode != "no-etag":
+            self.send_header("ETag", etag)
+        if mode != "no-last-modified":
+            self.send_header("Last-Modified", last_modified)
+        self.send_header("Content-Type", "application/vnd.comicbook+zip")
+        self.send_header("Content-Length", str(advertised_length))
+        if status == 206:
+            range_start = start + 1 if mode == "bad-range" else start
+            self.send_header("Content-Range", f"bytes {range_start}-{end}/{total}")
+        self.send_header("Connection", "close")
+        self.end_headers()
+
+        sent = 0
+        try:
+            limit = len(body) // 2 if mode == "drop" else len(body)
+            while sent < limit:
+                chunk = body[sent : min(sent + 16384, limit)]
+                self.wfile.write(chunk)
+                self.wfile.flush()
+                sent += len(chunk)
+                if mode == "slow":
+                    time.sleep(0.01)
+            if mode == "drop":
+                self.connection.shutdown(socket.SHUT_RDWR)
+                self.connection.close()
+        except (BrokenPipeError, ConnectionResetError, OSError):
+            pass
+        finally:
+            self.server.log_request_data(self._record(status, sent, mode))
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--file", required=True)
+    parser.add_argument("--port", type=int, default=0)
+    parser.add_argument("--port-file", required=True)
+    parser.add_argument("--log-file")
+    parser.add_argument("--username", default="reader")
+    parser.add_argument("--password", default="secret")
+    parser.add_argument("--allow-anonymous", action="store_true")
+    args = parser.parse_args()
+
+    server = FixtureServer(("127.0.0.1", args.port), Handler, args)
+    port_tmp = args.port_file + ".tmp"
+    with open(port_tmp, "w", encoding="ascii") as output:
+        output.write(str(server.server_port))
+        output.flush()
+        os.fsync(output.fileno())
+    os.replace(port_tmp, args.port_file)
+    try:
+        server.serve_forever(poll_interval=0.05)
+    finally:
+        server.server_close()
+
+
+if __name__ == "__main__":
+    main()
diff --git a/spec/unit/webdav_range_stream_spec.lua b/spec/unit/webdav_range_stream_spec.lua
new file mode 100644
index 00000000..2b876a15
--- /dev/null
+++ b/spec/unit/webdav_range_stream_spec.lua
@@ -0,0 +1,324 @@
+local Archiver = require("ffi/archiver")
+local DrawContext = require("ffi/drawcontext")
+local M = require("ffi/mupdf")
+local ffiUtil = require("ffi/util")
+local lfs = require("libs/libkoreader-lfs")
+
+local function shellQuote(value)
+    return "'" .. tostring(value):gsub("'", "'\\''") .. "'"
+end
+
+local function readFile(path)
+    local file = assert(io.open(path, "rb"))
+    local data = file:read("*all")
+    file:close()
+    return data
+end
+
+local function waitForFile(path)
+    for _ = 1, 200 do
+        local file = io.open(path, "rb")
+        if file then
+            local value = file:read("*all")
+            file:close()
+            if value ~= "" then return value end
+        end
+        ffiUtil.usleep(25000)
+    end
+end
+
+local function waitForLogValue(path, pattern)
+    for _ = 1, 200 do
+        local file = io.open(path, "rb")
+        if file then
+            local data = file:read("*all")
+            file:close()
+            local value = data:match(pattern)
+            if value then return tonumber(value) end
+        end
+        ffiUtil.usleep(25000)
+    end
+end
+
+local function startServer(fixture, allow_anonymous)
+    local port_file = os.tmpname()
+    local log_file = os.tmpname()
+    os.remove(port_file)
+    os.remove(log_file)
+    local args = {
+        os.getenv("PYTHON") or "python3",
+        "spec/base/support/webdav_range_server.py",
+        "--file", fixture,
+        "--port-file", port_file,
+        "--log-file", log_file,
+    }
+    if allow_anonymous then table.insert(args, "--allow-anonymous") end
+    local escaped = {}
+    for _, arg in ipairs(args) do table.insert(escaped, shellQuote(arg)) end
+    local command = table.concat(escaped, " ")
+    local pid = ffiUtil.runInSubProcess(function()
+        os.execute(command)
+    end)
+    assert.is_truthy(pid)
+    local port = tonumber(waitForFile(port_file))
+    assert.is_truthy(port)
+    return {
+        pid = pid,
+        port = port,
+        port_file = port_file,
+        log_file = log_file,
+    }
+end
+
+local function stopServer(server)
+    if not server then return end
+    ffiUtil.terminateSubProcess(server.pid)
+    ffiUtil.isSubProcessDone(server.pid, true)
+    os.remove(server.port_file)
+    os.remove(server.log_file)
+end
+
+local function urlEncode(value)
+    return (value:gsub("([^%w%-%.%_%~])", function(char)
+        return string.format("%%%02X", string.byte(char))
+    end))
+end
+
+local function assertErrorContains(ok, err, text)
+    assert.is_false(ok)
+    assert.is_truthy(tostring(err):find(text, 1, true), tostring(err))
+end
+
+describe("MuPDF WebDAV range stream", function()
+    local fixture
+    local fixture_size
+    local server
+    local anonymous_server
+    local base_url
+    local standard_options
+
+    setup(function()
+        local home = assert(os.getenv("KO_HOME"))
+        fixture = home .. "/webdav-range-test.cbz"
+        local image = readFile("spec/base/unit/data/sample.jpg")
+        local writer = Archiver.Writer:new()
+        assert.is_true(writer:open(fixture, "zip"))
+        assert.is_true(writer:setZipCompression("store"))
+        assert.is_true(writer:addFileFromMemory("pages/001.jpg", image))
+        assert.is_true(writer:addFileFromMemory("padding-1.bin", string.rep("A", 2 * 1024 * 1024)))
+        assert.is_true(writer:setZipCompression("deflate"))
+        assert.is_true(writer:addFileFromMemory("pages/002.jpg", image))
+        assert.is_true(writer:setZipCompression("store"))
+        assert.is_true(writer:addFileFromMemory("padding-2.bin", string.rep("B", 2 * 1024 * 1024)))
+        assert.is_true(writer:setZipCompression("deflate"))
+        assert.is_true(writer:addFileFromMemory("pages/003.jpg", image))
+        writer:close()
+        fixture_size = assert(lfs.attributes(fixture, "size"))
+
+        server = startServer(fixture, false)
+        anonymous_server = startServer(fixture, true)
+        base_url = string.format("http://127.0.0.1:%d", server.port)
+        standard_options = {
+            url = base_url .. "/book.cbz",
+            username = "reader",
+            password = "secret",
+            expected_size = fixture_size,
+            etag = '"fixture-v1"',
+            last_modified = "Wed, 15 Jul 2026 00:00:00 GMT",
+            magic = "book.cbz",
+            display_name = "book.cbz",
+            extension = "cbz",
+            block_size = 64 * 1024,
+            cache_limit = 128 * 1024,
+        }
+    end)
+
+    teardown(function()
+        stopServer(server)
+        stopServer(anonymous_server)
+        if fixture then os.remove(fixture) end
+    end)
+
+    it("probes one byte and reports validators", function()
+        local result = M.probeRemote(standard_options)
+        assert.equals(fixture_size, result.content_length)
+        assert.equals('"fixture-v1"', result.etag)
+        assert.equals("Wed, 15 Jul 2026 00:00:00 GMT", result.last_modified)
+        assert.is_true(result.strong_etag)
+        assert.equals(206, result.http_status)
+    end)
+
+    it("renders arbitrary CBZ pages without transferring the archive", function()
+        local doc = M.openRemoteDocument(standard_options)
+        assert.equals(3, doc:getPages())
+        local dc = DrawContext.new()
+        for _, number in ipairs({ 1, 3, 2, 1 }) do
+            local page = doc:openPage(number)
+            local width, height = page:getSize(dc)
+            assert.is_true(width > 0 and height > 0)
+            page:close()
+        end
+        local stats = doc:getNetworkStats()
+        assert.is_true(stats.bytes_received < fixture_size)
+        assert.is_true(stats.request_count > 1)
+        assert.is_true(stats.peak_cached_bytes <= standard_options.cache_limit)
+        assert.is_true(stats.cached_bytes <= standard_options.cache_limit)
+        doc:clearRemoteCache()
+        assert.equals(0, doc:getNetworkStats().cached_bytes)
+        doc:close()
+    end)
+
+    it("repeatedly opens and closes without retaining native blocks", function()
+        for _ = 1, 5 do
+            local doc = M.openRemoteDocument(standard_options)
+            local page = doc:openPage(2)
+            page:close()
+            doc:close()
+        end
+    end)
+
+    it("rejects ignored ranges, bad ranges, truncation, auth failures, and changes", function()
+        local ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=ignore",
+            username = "reader", password = "secret", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "ignored the byte range")
+        local ignored_bytes = assert(waitForLogValue(server.log_file,
+            '"bytes_sent": (%d+)[^\n]-"mode": "ignore"'))
+        assert.is_true(ignored_bytes < fixture_size)
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=bad-range",
+            username = "reader", password = "secret", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "Content-Range does not match")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=truncate",
+            username = "reader", password = "secret", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "truncated byte range")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz",
+            username = "reader", password = "wrong", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "authentication failed")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=changed",
+            username = "reader", password = "secret", expected_size = fixture_size,
+            etag = '"fixture-v1"',
+        })
+        assertErrorContains(ok, err, "remote file changed")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz",
+            username = "reader", password = "secret", expected_size = fixture_size + 1,
+        })
+        assertErrorContains(ok, err, "remote file size changed")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=missing",
+            username = "reader", password = "secret", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "remote file is unavailable")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=no-etag",
+            username = "reader", password = "secret", expected_size = fixture_size,
+            etag = '"fixture-v1"',
+        })
+        assertErrorContains(ok, err, "omitted the expected ETag")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=changed-last-modified",
+            username = "reader", password = "secret", expected_size = fixture_size,
+            last_modified = "Wed, 15 Jul 2026 00:00:00 GMT",
+        })
+        assertErrorContains(ok, err, "Last-Modified value changed")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=no-last-modified",
+            username = "reader", password = "secret", expected_size = fixture_size,
+            last_modified = "Wed, 15 Jul 2026 00:00:00 GMT",
+        })
+        assertErrorContains(ok, err, "omitted the expected Last-Modified")
+
+        ok, err = pcall(M.probeRemote, {
+            url = base_url .. "/book.cbz?mode=drop",
+            username = "reader", password = "secret", expected_size = fixture_size,
+        })
+        assertErrorContains(ok, err, "truncated byte range")
+    end)
+
+    it("does not forward credentials across an origin-changing redirect", function()
+        local target = string.format("http://127.0.0.1:%d/book.cbz", anonymous_server.port)
+        local result = M.probeRemote({
+            url = base_url .. "/redirect?target=" .. urlEncode(target),
+            username = "reader",
+            password = "secret",
+            expected_size = fixture_size,
+        })
+        assert.equals(fixture_size, result.content_length)
+        ffiUtil.usleep(50000)
+        local log = readFile(anonymous_server.log_file)
+        assert.is_nil(log:find('"authorization_present": true', 1, true))
+        assert.is_truthy(log:find('"authorization_present": false', 1, true))
+    end)
+
+    it("streams through a redirect using Last-Modified when GET omits ETag", function()
+        local target = string.format("http://127.0.0.1:%d/book.cbz?mode=no-etag",
+            anonymous_server.port)
+        local options = {
+            url = base_url .. "/redirect?target=" .. urlEncode(target),
+            username = "reader",
+            password = "secret",
+            expected_size = fixture_size,
+            last_modified = "Wed, 15 Jul 2026 00:00:00 GMT",
+            magic = "redirected.cbz",
+            extension = "cbz",
+            block_size = 64 * 1024,
+            cache_limit = 128 * 1024,
+        }
+        local doc = M.openRemoteDocument(options)
+        assert.equals(3, doc:getPages())
+        local page = doc:openPage(2)
+        page:close()
+        assert.is_true(doc:getNetworkStats().bytes_received < fixture_size)
+        doc:close()
+    end)
+
+    it("ignores weak ETags and validates Last-Modified instead", function()
+        local result = M.probeRemote({
+            url = base_url .. "/book.cbz?mode=no-etag",
+            username = "reader",
+            password = "secret",
+            expected_size = fixture_size,
+            etag = 'W/"fixture-v1"',
+            last_modified = "Wed, 15 Jul 2026 00:00:00 GMT",
+        })
+        assert.equals(206, result.http_status)
+        assert.is_nil(result.etag)
+        assert.equals("Wed, 15 Jul 2026 00:00:00 GMT", result.last_modified)
+    end)
+
+    it("surfaces strict transfer ceilings instead of returning blank pages", function()
+        local opening_options = {}
+        for key, value in pairs(standard_options) do opening_options[key] = value end
+        opening_options.strict_mode = true
+        opening_options.opening_transfer_limit = 1
+        local ok, err = pcall(M.openRemoteDocument, opening_options)
+        assertErrorContains(ok, err, "opening transfer limit exceeded")
+
+        local page_options = {}
+        for key, value in pairs(standard_options) do page_options[key] = value end
+        page_options.strict_mode = true
+        page_options.operation_transfer_limit = 1
+        local doc = M.openRemoteDocument(page_options)
+        doc:clearRemoteCache()
+        ok, err = pcall(doc.openPage, doc, 2)
+        assertErrorContains(ok, err, "page transfer limit exceeded")
+        doc:close()
+    end)
+end)
